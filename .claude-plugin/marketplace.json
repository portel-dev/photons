{
  "name": "photons-marketplace",
  "owner": {
    "name": "portel-dev"
  },
  "metadata": {
    "description": "A small, polished gallery of ready-to-use photons: agent-facing apps, developer tools, and trustworthy utilities you can install directly.",
    "version": "1.33.2"
  },
  "plugins": [
    {
      "name": "boards",
      "description": "Modern Kanban Boards Photon\n\nTask management for humans and AI. Use named instances (`_use('project-name')`) for per-project boards. Perfect for project planning, AI working memory across sessions, and human-AI collaboration on shared tasks.",
      "source": "./",
      "strict": false,
      "hooks": [
        "./.claude-plugin/hooks.json"
      ],
      "mcpServers": {
        "boards": {
          "command": "photon",
          "args": [
            "mcp",
            "boards"
          ]
        }
      }
    },
